# API .env - Azure OpenAI and Voice configuration
# Copy this file to .env and fill in your actual values.

# Azure Cognitive Services endpoint for voice/realtime API
AZURE_VOICE_ENDPOINT=https://your-resource.cognitiveservices.azure.com

# Azure Cognitive Services API key
AZURE_VOICE_KEY=your_key_here

# Enable local tracing (set to false in production)
LOCAL_TRACING_ENABLED=true

# Azure OpenAI endpoint (used by prompty for chat completions)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Azure OpenAI API key
AZURE_OPENAI_API_KEY=your_key_here

# Azure OpenAI deployment names
# GA Realtime API deployment (gpt-realtime). For preview fallback, use gpt-4o-realtime-preview.
AZURE_VOICE_DEPLOYMENT=gpt-realtime
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# API mode: "ga" uses /openai/v1/ path with no api-version (requires openai.azure.com endpoint).
# "preview" uses /openai/realtime path with api-version=2025-04-01-preview (works with cognitiveservices endpoints).
AZURE_VOICE_API_MODE=preview
