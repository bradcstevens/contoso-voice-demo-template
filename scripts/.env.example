# Scripts .env - DigiKey API OAuth credentials
# Copy this file to .env and fill in your actual values.
# Used by fetch_product_index.sh to authenticate with the DigiKey API.

DIGIKEY_CLIENT_ID="your_client_id_here"
DIGIKEY_CLIENT_SECRET="your_client_secret_here"
GRANT_TYPE="client_credentials"
ACCESS_TOKEN_URL="https://api.digikey.com/v1/oauth2/token"
CONTENT_TYPE="application/x-www-form-urlencoded"
