# Root .env - API keys for development tools
# Copy this file to .env and fill in your actual keys.

# OpenAI API key (optional, for development tooling)
OPENAI_API_KEY=your_key_here

# Anthropic API key (optional, for development tooling)
ANTHROPIC_API_KEY=your_key_here

# Perplexity API key (optional, for research features)
PERPLEXITY_API_KEY=your_key_here

# Google API key (optional, for development tooling)
GOOGLE_API_KEY=your_key_here
